# ========= ATLAS backend configuration =========
# Copy to `.env` and adjust.

# ---- Ollama (local LLM + embeddings) ----
OLLAMA_BASE_URL=http://localhost:11434
# Chat / reasoning model (pull first:  ollama pull llama3.1)
OLLAMA_LLM_MODEL=llama3.1
# Embedding model (pull first:  ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.1
# Request timeout to Ollama, seconds
OLLAMA_TIMEOUT=120

# ---- Vector store ----
FAISS_INDEX_DIR=./faiss_index
# Rebuild the FAISS index on startup even if one exists on disk
FAISS_FORCE_REBUILD=false

# ---- Data ----
DATA_DIR=./data
# Deterministic seed for synthetic telemetry (matches the frontend)
TELEMETRY_SEED=20260614

# ---- CORS (the React frontend origin) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Email / alerting (SMTP). Leave SMTP_HOST empty to run in dry-run (log only). ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_FROM=atlas-bot@retailco.io
ALERT_TO=oncall-sre@retailco.io
ALERT_CC=platform-eng@retailco.io

# ---- Remediation ----
# When true, remediation actions are simulated (no real infra calls). Keep true unless wired to a real orchestrator.
REMEDIATION_DRY_RUN=true
